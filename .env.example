SECRET_KEY=change-me-in-production-use-a-long-random-string

DEBUG=False

ALLOWED_HOSTS=your-domain.com,www.your-domain.com



# Required when served over HTTPS (comma-separated, include scheme)

CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com



# Set to True only if the app is NOT already behind an HTTPS reverse proxy

SECURE_SSL_REDIRECT=False



# django.contrib.sites — used by allauth (set to your public domain)

SITE_DOMAIN=your-domain.com



# Host port mapped to container :8000 (default 8010 if unset)
HTTP_PORT=8010



# Google OAuth — https://console.cloud.google.com/

# Production redirect URI example:

# https://your-domain.com/accounts/google/login/callback/

GOOGLE_CLIENT_ID=

GOOGLE_CLIENT_SECRET=



# Only this Google account can manage the Users whitelist page

USER_MODULE_ADMIN_EMAIL=clu@taxnova.ca



# OpenAI — https://platform.openai.com/

OPENAI_API_KEY=



# Optional

OPENAI_TRANSCRIPTION_MODEL=whisper-1

OPENAI_SUMMARY_MODEL=gpt-4o-mini



# Optional Gunicorn tuning

# GUNICORN_WORKERS=2

# GUNICORN_THREADS=4

# GUNICORN_TIMEOUT=120

